# The wickra-darwin C ABI header and library are provided out-of-tree via
# the WKDARWIN_INC (include dir) and WKDARWIN_LIB (library dir)
# environment variables, set by CI / the installer. The Makevars do not bake an
# rpath; the loader must find the shared library via LD_LIBRARY_PATH /
# DYLD_LIBRARY_PATH at run time.
PKG_CPPFLAGS = -I$(WKDARWIN_INC)
PKG_LIBS = -L$(WKDARWIN_LIB) -lwickra_darwin
